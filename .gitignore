tools/
scripts/
data/mock/
data/raw/contributions/

# Local data files while preserving scaffold folders
data/raw/*
!data/raw/fiber_wearable_patents_sources.csv
!data/raw/patent_collection_review_needed.csv
data/processed/*
!data/processed/.gitkeep
data/processed/*.db
data/processed/*.sqlite
data/processed/*.sqlite3
data/exports/*
!data/exports/.gitkeep
data/cache/
# Large raw USPTO bulk intermediate input (kept local; outputs are committed)
data/JSONS_USPTO/

# Claude Code local workspace
.claude/

